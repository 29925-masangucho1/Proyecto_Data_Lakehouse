{
  "description": "Canonical unified schema for all NYC taxi trip records",
  "version": "1.0",
  "columns": [
    {"name": "trip_id", "type": "string", "nullable": false, "description": "Unique trip identifier (MD5 hash of source + pickup + dropoff)"},
    {"name": "service_type", "type": "string", "nullable": false, "description": "Service type: yellow, green, fhvhv"},
    {"name": "vendor_id", "type": "long", "nullable": true, "description": "Vendor/provider code"},
    {"name": "pickup_datetime", "type": "timestamp_ntz", "nullable": false, "description": "Pickup date and time"},
    {"name": "dropoff_datetime", "type": "timestamp_ntz", "nullable": false, "description": "Dropoff date and time"},
    {"name": "passenger_count", "type": "double", "nullable": true, "description": "Number of passengers"},
    {"name": "trip_distance", "type": "double", "nullable": false, "description": "Trip distance in miles"},
    {"name": "pickup_location_id", "type": "long", "nullable": true, "description": "Pickup location zone ID"},
    {"name": "dropoff_location_id", "type": "long", "nullable": true, "description": "Dropoff location zone ID"},
    {"name": "payment_type", "type": "double", "nullable": true, "description": "Payment method code"},
    {"name": "fare_amount", "type": "double", "nullable": true, "description": "Fare amount"},
    {"name": "extra_amount", "type": "double", "nullable": true, "description": "Extra charges"},
    {"name": "mta_tax", "type": "double", "nullable": true, "description": "MTA tax amount"},
    {"name": "tip_amount", "type": "double", "nullable": true, "description": "Tip amount"},
    {"name": "tolls_amount", "type": "double", "nullable": true, "description": "Tolls amount"},
    {"name": "total_amount", "type": "double", "nullable": true, "description": "Total charged amount"},
    {"name": "congestion_surcharge", "type": "double", "nullable": true, "description": "Congestion surcharge"},
    {"name": "airport_fee", "type": "double", "nullable": true, "description": "Airport fee"},
    {"name": "trip_duration_minutes", "type": "double", "nullable": true, "description": "Trip duration in minutes"},
    {"name": "average_speed_mph", "type": "double", "nullable": true, "description": "Average speed in mph"},
    {"name": "fare_per_mile", "type": "double", "nullable": true, "description": "Fare amount per mile"},
    {"name": "tip_percentage", "type": "double", "nullable": true, "description": "Tip as percentage of fare"},
    {"name": "is_airport_trip", "type": "boolean", "nullable": true, "description": "Indicates if trip involved airport"},
    {"name": "is_suspicious_trip", "type": "boolean", "nullable": false, "description": "Flag for suspicious trip indicators"},
    {"name": "year", "type": "int", "nullable": false, "description": "Partition year"},
    {"name": "month", "type": "int", "nullable": false, "description": "Partition month"},
    {"name": "source_file", "type": "string", "nullable": false, "description": "Original source filename"},
    {"name": "ingestion_timestamp", "type": "timestamp_ntz", "nullable": false, "description": "When the record was ingested"},
    {"name": "quality_status", "type": "string", "nullable": false, "description": "Quality status: valid, rejected_system, rejected_business"}
  ],
  "column_mapping": {
    "yellow": {
      "vendor_id": "VendorID",
      "pickup_datetime": "tpep_pickup_datetime",
      "dropoff_datetime": "tpep_dropoff_datetime",
      "passenger_count": "passenger_count",
      "trip_distance": "trip_distance",
      "pickup_location_id": "PULocationID",
      "dropoff_location_id": "DOLocationID",
      "payment_type": "payment_type",
      "fare_amount": "fare_amount",
      "extra_amount": "extra",
      "mta_tax": "mta_tax",
      "tip_amount": "tip_amount",
      "tolls_amount": "tolls_amount",
      "total_amount": "total_amount",
      "congestion_surcharge": "congestion_surcharge",
      "airport_fee": "airport_fee"
    },
    "green": {
      "vendor_id": "VendorID",
      "pickup_datetime": "lpep_pickup_datetime",
      "dropoff_datetime": "lpep_dropoff_datetime",
      "passenger_count": "passenger_count",
      "trip_distance": "trip_distance",
      "pickup_location_id": "PULocationID",
      "dropoff_location_id": "DOLocationID",
      "payment_type": "payment_type",
      "fare_amount": "fare_amount",
      "extra_amount": "extra",
      "mta_tax": "mta_tax",
      "tip_amount": "tip_amount",
      "tolls_amount": "tolls_amount",
      "total_amount": "total_amount",
      "congestion_surcharge": "congestion_surcharge",
      "airport_fee": null
    },
    "fhvhv": {
      "vendor_id": null,
      "pickup_datetime": "pickup_datetime",
      "dropoff_datetime": "dropOff_datetime",
      "passenger_count": null,
      "trip_distance": null,
      "pickup_location_id": "PUlocationID",
      "dropoff_location_id": "DOlocationID",
      "payment_type": null,
      "fare_amount": null,
      "extra_amount": null,
      "mta_tax": null,
      "tip_amount": null,
      "tolls_amount": null,
      "total_amount": null,
      "congestion_surcharge": null,
      "airport_fee": null
    }
  }
}
